<?xml version="1.0" encoding="utf-8"?>
<extension type="module" version="5.0" client="site" method="upgrade">
    <name>MOD_B3_MEDIABOX</name>
    <author>Hugo Fittipaldi</author>
    <creationDate>October 2017</creationDate>
    <copyright>Copyright (C) 2005 - 2018 Open Source Matters. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <authorEmail>hugo.fittipaldi@gmail.com</authorEmail>
    <version>1.0.0</version>
    <description>MOD_B3_MEDIABOX_XML_DESCRIPTION</description>
    <namespace path="src">Joomla\Module\B3Mediabox</namespace>
    <customContent />
    <files>
        <folder module="mod_b3_mediabox">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>
    <scriptfile>script.php</scriptfile>
    <media destination="mod_b3_mediabox" folder="media">
        <filename>joomla.asset.json</filename>
        <folder>css</folder>
    </media>
    <languages>
        <language tag="en-GB">language/en-GB/mod_b3_mediabox.ini</language>
        <language tag="en-GB">language/en-GB/mod_b3_mediabox.sys.ini</language>
        <language tag="pt-BR">language/pt-BR/mod_b3_mediabox.ini</language>
        <language tag="pt-BR">language/pt-BR/mod_b3_mediabox.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="options" label="COM_MODULES_BASIC_FIELDSET_LABEL">
                <field
                    name="prepare_content"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="MOD_B3_MEDIABOX_FIELD_PREPARE_CONTENT_LABEL"
                    description="MOD_B3_MEDIABOX_FIELD_PREPARE_CONTENT_DESC"
                    default="0"
                    filter="integer"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field
                    name="width"
                    type="number"
                    default="800"
                    label="MOD_B3_MEDIABOX_FIELD_WIDTH_LABEL"
                    description="MOD_B3_MEDIABOX_FIELD_WIDTH_DESC"
                    filter="integer"
                />

                <field
                    name="height"
                    type="number"
                    default="800"
                    label="MOD_B3_MEDIABOX_FIELD_HEIGHT_LABEL"
                    description="MOD_B3_MEDIABOX_FIELD_HEIGHT_DESC"
                    filter="integer"
                />

                <field
                    name="border"
                    type="number"
                    default="0"
                    label="MOD_B3_MEDIABOX_FIELD_BORDER_LABEL"
                    description="MOD_B3_MEDIABOX_FIELD_BORDER_DESC"
                    filter="integer"
                />

                <field
                    name="borderColor"
                    type="color"
                    default="#fff"
                    label="MOD_B3_MEDIABOX_FIELD_BORDER_COLOR_LABEL"
                    description="MOD_B3_MEDIABOX_FIELD_BORDER_COLOR_DESC"
                />
            </fieldset>

            <fieldset name="advanced">
                <field
                    name="layout"
                    type="modulelayout"
                    label="JFIELD_ALT_LAYOUT_LABEL"
                    class="form-select"
                    validate="moduleLayout"
                />

                <field
                    name="moduleclass_sfx"
                    type="textarea"
                    label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                    rows="3"
                    validate="CssIdentifier"
                />

                <field
                    name="cache"
                    type="list"
                    label="COM_MODULES_FIELD_CACHING_LABEL"
                    default="1"
                    filter="integer"
                    validate="options"
                >
                    <option value="1">JGLOBAL_USE_GLOBAL</option>
                    <option value="0">COM_MODULES_FIELD_VALUE_NOCACHING</option>
                </field>

                <field
                    name="cache_time"
                    type="number"
                    label="COM_MODULES_FIELD_CACHE_TIME_LABEL"
                    default="900"
                    filter="integer"
                />

                <field
                    name="cachemode"
                    type="hidden"
                    default="static"
                    >
                    <option value="static"></option>
                </field>
            </fieldset>
        </fields>
    </config>

    <updateservers>
        <server type="extension" priority="1" name="B3 Mediabox Module Update Site">https://raw.githubusercontent.com/hfittipaldi/mod_b3_mediabox/master/updates.xml</server>
    </updateservers>
</extension>
