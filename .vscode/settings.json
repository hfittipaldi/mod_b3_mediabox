{
    // output: generate files to ...
    // ~ = path starts relative from scss-file
  "liveSassCompile.settings.formats": [
        {
            "format": "expanded",
            "extensionName": ".css",
            "savePath": "~/../css"
        },
        // ad a compressed version
        {
            "format": "compressed",
            "extensionName": ".min.css",
            "savePath": "~/../css"
        }
        // optional: add more outputs ...
    ],
}